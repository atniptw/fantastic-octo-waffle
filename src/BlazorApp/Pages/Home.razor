@page "/"
@implements IAsyncDisposable

@using System.IO.Compression
@using RepoMod.Glb.Abstractions
@using RepoMod.Glb.Contracts
@using RepoMod.Parser.Abstractions
@using RepoMod.Parser.Contracts
@using RepoMod.Parser.Implementation
@inject HttpClient Http
@inject IJSRuntime JS
@inject ISceneExtractor SceneExtractor
@inject IGlbCompositionPlanner GlbCompositionPlanner
@inject IGlbSerializer GlbSerializer

<PageTitle>Repo Mod Composer</PageTitle>

<section class="home-page">
	<header class="home-header">
		<h1>Repo Mod Composer</h1>
		<p>Upload mod zip files, toggle assets, and preview composed output.</p>
	</header>

	<div class="layout-grid">
		<section class="left-pane">
			<div class="panel">
				<h2>Base Avatar</h2>
				<p><strong>Source:</strong> @BundledAvatarPath</p>
				<p><strong>Status:</strong> @avatarStatus</p>
			</div>

			<div class="panel">
				<h2>Upload Mods (.zip)</h2>
				<InputFile OnChange="HandleZipUploadAsync" accept=".zip" />
				@if (!string.IsNullOrWhiteSpace(uploadStatus))
				{
					<p class="status">@uploadStatus</p>
				}
			</div>

			<div class="panel">
				<h2>Extracted Assets</h2>
				@if (modAssets.Count == 0)
				{
					<p>No .hhh assets uploaded yet.</p>
				}
				else
				{
					<ul class="asset-list">
						@foreach (var asset in modAssets.OrderBy(item => item.AssetName, StringComparer.OrdinalIgnoreCase))
						{
							<li>
								<label>
									<input type="checkbox" checked="@asset.Enabled" @onchange="async args => await ToggleAssetAsync(asset.AssetId, args)" />
									<span>@asset.AssetName</span>
								</label>
								<div class="meta">@asset.ModSourceName • @asset.ByteCount bytes • @asset.ImportedAt.LocalDateTime</div>
							</li>
						}
					</ul>
				}
			</div>
		</section>

		<section class="right-pane">
			<div class="panel preview-panel">
				<h2>Preview</h2>
				<div class="preview-placeholder">three.js preview canvas will render here</div>
				<p class="status">@composeStatus</p>
			</div>

			<div class="panel">
				<h2>Diagnostics</h2>
				@if (diagnostics.Count == 0)
				{
					<p>No diagnostics.</p>
				}
				else
				{
					<ul class="diagnostics-list">
						@foreach (var item in diagnostics)
						{
							<li>@item</li>
						}
					</ul>
				}
			</div>
		</section>
	</div>
</section>

@code {
	private const string BundledAvatarPath = "assets/avatar/MoreHead-Asset-Pack_v1.3.unitypackage";
	private const string AssetStoreModulePath = "./js/assetStore.js";

	private readonly List<UploadedAssetEntry> modAssets = [];
	private readonly List<string> diagnostics = [];

	private IJSObjectReference? assetStoreModule;
	private ConverterScene? avatarConverterScene;
	private string avatarStatus = "Loading bundled avatar package...";
	private string uploadStatus = string.Empty;
	private string composeStatus = "No composed output yet.";

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var bytes = await Http.GetByteArrayAsync(BundledAvatarPath);
			if (bytes.Length == 0)
			{
				avatarStatus = "Bundled avatar package is empty.";
				AddDiagnostic(avatarStatus);
			}
			else
			{
				var avatarResult = ParseSceneFromBytes(bytes, ".unitypackage", isAvatarScene: true);
				if (!avatarResult.Success || avatarResult.Scene is null)
				{
					avatarStatus = $"Bundled avatar parse failed: {avatarResult.Error ?? "Unknown error"}";
					AddDiagnostic(avatarStatus);
				}
				else
				{
					var projection = ConverterSceneMapper.MapWithDiagnostics(avatarResult.Scene);
					avatarConverterScene = projection.Scene;
					avatarStatus = $"Loaded ({bytes.Length:n0} bytes, {projection.Scene.Primitives.Count} primitives)";

					foreach (var warning in avatarResult.Scene.Warnings)
					{
						AddDiagnostic($"Avatar: {warning}");
					}

					foreach (var diagnostic in projection.Diagnostics)
					{
						AddDiagnostic($"Avatar [{diagnostic.Severity}] {diagnostic.Code}: {diagnostic.Message}");
					}
				}
			}
		}
		catch (Exception ex)
		{
			avatarStatus = $"Failed to load bundled avatar: {ex.Message}";
			AddDiagnostic(avatarStatus);
		}

		await LoadPersistedAssetsAsync();
	}

	private async Task HandleZipUploadAsync(InputFileChangeEventArgs args)
	{
		var file = args.File;
		if (file is null)
		{
			return;
		}

		uploadStatus = $"Processing {file.Name}...";

		try
		{
			await using var uploadStream = file.OpenReadStream(maxAllowedSize: 128 * 1024 * 1024);
			using var memory = new MemoryStream();
			await uploadStream.CopyToAsync(memory);
			memory.Position = 0;

			using var archive = new ZipArchive(memory, ZipArchiveMode.Read, leaveOpen: false);
			var extractedCount = 0;
			foreach (var entry in archive.Entries)
			{
				if (!entry.FullName.EndsWith(".hhh", StringComparison.OrdinalIgnoreCase))
				{
					continue;
				}

				if (modAssets.Any(item => string.Equals(item.AssetName, entry.FullName, StringComparison.OrdinalIgnoreCase)
										  && string.Equals(item.ModSourceName, file.Name, StringComparison.OrdinalIgnoreCase)))
				{
					continue;
				}

				await using var entryStream = entry.Open();
				using var entryMemory = new MemoryStream();
				await entryStream.CopyToAsync(entryMemory);
				var contentBytes = entryMemory.ToArray();
				if (contentBytes.Length == 0)
				{
					continue;
				}

				modAssets.Add(new UploadedAssetEntry(
					$"{file.Name}:{entry.FullName}",
					file.Name,
					entry.FullName,
					Convert.ToBase64String(contentBytes),
					contentBytes.Length,
					DateTimeOffset.UtcNow,
					true));
				extractedCount++;
			}

			uploadStatus = extractedCount > 0
				? $"Imported {extractedCount} .hhh file(s) from {file.Name}."
				: $"No .hhh files found in {file.Name}.";

			await ComposePreviewAsync();
			await PersistAssetsAsync();
		}
		catch (Exception ex)
		{
			uploadStatus = $"Failed to process zip: {ex.Message}";
			AddDiagnostic(uploadStatus);
		}
	}

	private async Task ToggleAssetAsync(string assetId, ChangeEventArgs args)
	{
		var enabled = args.Value switch
		{
			bool boolValue => boolValue,
			string text => string.Equals(text, "true", StringComparison.OrdinalIgnoreCase) || text == "on",
			_ => false
		};

		var index = modAssets.FindIndex(item => item.AssetId == assetId);
		if (index < 0)
		{
			return;
		}

		var current = modAssets[index];
		modAssets[index] = current with { Enabled = enabled };
		await ComposePreviewAsync();
		await PersistAssetsAsync();
	}

	private async Task LoadPersistedAssetsAsync()
	{
		try
		{
			var module = await GetAssetStoreModuleAsync();
			var stored = await module.InvokeAsync<List<StoredAssetEntry>>("loadAssets");
			if (stored is null || stored.Count == 0)
			{
				return;
			}

			modAssets.Clear();
			modAssets.AddRange(stored.Select(item => new UploadedAssetEntry(
				item.AssetId,
				item.ModSourceName,
				item.AssetName,
				item.ContentBase64,
				item.ByteCount,
				item.ImportedAt,
				item.Enabled)));

			uploadStatus = $"Restored {stored.Count} asset(s) from IndexedDB.";
			await ComposePreviewAsync();
		}
		catch (JSException ex)
		{
			AddDiagnostic($"IndexedDB restore skipped: {ex.Message}");
		}
	}

	private async Task PersistAssetsAsync()
	{
		try
		{
			var module = await GetAssetStoreModuleAsync();
			var stored = modAssets.Select(item => new StoredAssetEntry(
				item.AssetId,
				item.ModSourceName,
				item.AssetName,
				item.ContentBase64,
				item.ByteCount,
				item.ImportedAt,
				item.Enabled));
			await module.InvokeVoidAsync("saveAssets", stored);
		}
		catch (JSException ex)
		{
			AddDiagnostic($"IndexedDB save failed: {ex.Message}");
		}
	}

	private async Task<IJSObjectReference> GetAssetStoreModuleAsync()
	{
		assetStoreModule ??= await JS.InvokeAsync<IJSObjectReference>("import", AssetStoreModulePath);
		return assetStoreModule;
	}

	private async Task ComposePreviewAsync()
	{
		if (avatarConverterScene is null)
		{
			composeStatus = "Compose skipped: avatar scene is not available.";
			AddDiagnostic(composeStatus);
			return;
		}

		var selectedCount = modAssets.Count(item => item.Enabled);
		if (selectedCount == 0)
		{
			composeStatus = "Compose skipped: no enabled assets.";
			return;
		}

		var selections = new List<GlbCosmeticSelection>();
		foreach (var asset in modAssets.Where(item => item.Enabled).OrderBy(item => item.AssetId, StringComparer.Ordinal))
		{
			byte[] assetBytes;
			try
			{
				assetBytes = Convert.FromBase64String(asset.ContentBase64);
			}
			catch (FormatException ex)
			{
				AddDiagnostic($"Asset '{asset.AssetName}' has invalid content encoding: {ex.Message}");
				continue;
			}

			var sceneResult = ParseSceneFromBytes(assetBytes, ".hhh", isAvatarScene: false);
			if (!sceneResult.Success || sceneResult.Scene is null)
			{
				AddDiagnostic($"Asset '{asset.AssetName}' parse failed: {sceneResult.Error ?? "Unknown error"}");
				continue;
			}

			foreach (var warning in sceneResult.Scene.Warnings)
			{
				AddDiagnostic($"Asset '{asset.AssetName}' warning: {warning}");
			}

			var projection = ConverterSceneMapper.MapWithDiagnostics(sceneResult.Scene);
			foreach (var diagnostic in projection.Diagnostics)
			{
				AddDiagnostic($"Asset '{asset.AssetName}' [{diagnostic.Severity}] {diagnostic.Code}: {diagnostic.Message}");
			}

			var slotTag = sceneResult.Scene.Assets
				.FirstOrDefault(item => item.IsCosmeticCandidate)?.SlotTag;
			var candidatePaths = sceneResult.Scene.AttachmentHints
				.SelectMany(item => item.CandidateNodePaths)
				.Where(path => !string.IsNullOrWhiteSpace(path))
				.Distinct(StringComparer.OrdinalIgnoreCase)
				.ToArray();

			selections.Add(new GlbCosmeticSelection(
				asset.AssetId,
				slotTag,
				projection.Scene,
				candidatePaths,
				true));
		}

		if (selections.Count == 0)
		{
			composeStatus = $"Compose skipped: no valid parsed scenes from {selectedCount} selected asset(s).";
			return;
		}

		var composition = GlbCompositionPlanner.BuildComposition(avatarConverterScene, selections);
		var buildResult = GlbSerializer.Build(composition);

		foreach (var warning in composition.Warnings)
		{
			AddDiagnostic($"Compose warning: {warning}");
		}

		foreach (var diagnostic in buildResult.Diagnostics)
		{
			AddDiagnostic($"GLB [{diagnostic.Severity}] {diagnostic.Code}: {diagnostic.Message}");
		}

		composeStatus = $"Composed {selections.Count} asset(s) into GLB ({buildResult.GlbBytes.Length:n0} bytes) at {DateTimeOffset.Now:T}.";
		await Task.CompletedTask;
	}

	private ParseSceneResult ParseSceneFromBytes(byte[] bytes, string extension, bool isAvatarScene)
	{
		if (bytes.Length == 0)
		{
			return ParseSceneResult.Failed("Input payload is empty.");
		}

		var tempPath = Path.Combine(Path.GetTempPath(), $"repomod-{Guid.NewGuid():N}{extension}");
		try
		{
			File.WriteAllBytes(tempPath, bytes);
			return isAvatarScene
				? SceneExtractor.ParseUnityPackage(tempPath)
				: SceneExtractor.ParseCosmeticBundle(tempPath);
		}
		catch (Exception ex)
		{
			return ParseSceneResult.Failed(ex.Message);
		}
		finally
		{
			try
			{
				if (File.Exists(tempPath))
				{
					File.Delete(tempPath);
				}
			}
			catch
			{
			}
		}
	}

	private void AddDiagnostic(string message)
	{
		diagnostics.Add(message);
		if (diagnostics.Count > 24)
		{
			diagnostics.RemoveRange(0, diagnostics.Count - 24);
		}
	}

	private sealed record UploadedAssetEntry(
		string AssetId,
		string ModSourceName,
		string AssetName,
		string ContentBase64,
		int ByteCount,
		DateTimeOffset ImportedAt,
		bool Enabled);

	private sealed record StoredAssetEntry(
		string AssetId,
		string ModSourceName,
		string AssetName,
		string ContentBase64,
		int ByteCount,
		DateTimeOffset ImportedAt,
		bool Enabled);

	public async ValueTask DisposeAsync()
	{
		if (assetStoreModule is not null)
		{
			await assetStoreModule.DisposeAsync();
		}
	}
}
